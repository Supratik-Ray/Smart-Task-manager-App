{
  "name": "task-manager-apis",
  "version": "1.0.0",
  "description": "APIs for Task manager app",
  "license": "ISC",
  "author": "Supratik Ray",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node -r tsconfig-paths/register dist/src/index.js",
    "dev": "npx tsx watch ./src/server.ts",
    "db:generate": "npx drizzle-kit generate",
    "db:migrate": "npx drizzle-kit migrate",
    "db:seed": "tsx ./src/db/seed.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.3",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0"
  }
}
