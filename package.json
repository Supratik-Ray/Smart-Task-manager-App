{
  "name": "smart-task-manager-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev:mobile": "npm run start -w apps/mobile",
    "dev:backend": "npm run dev -w apps/backend",
    "build:backend": "npm run build -w @smart-task-manager/shared && npm run build -w task-manager-apis",
    "install:all": "npm install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Supratik-Ray/Smart-Task-manager-App.git"
  },
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Supratik-Ray/Smart-Task-manager-App/issues"
  },
  "homepage": "https://github.com/Supratik-Ray/Smart-Task-manager-App#readme"
}
