{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,

    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "types": ["node", "express"]
  },
  "include": ["src"]
}
